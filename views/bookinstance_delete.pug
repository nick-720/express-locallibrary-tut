extends layout

block content



  p #[strong Title: ]
    a(href=bookInstance.url) #{bookInstance.book.title}
  p #[strong Imprint:] #{bookInstance.imprint}

  p #[strong Status: ]
    if bookInstance.status=='Available'
      span.text-success #{bookInstance.status}
    else if bookInstance.status=='Maintenance'
      span.text-danger #{bookInstance.status}
    else
      span.text-warning #{bookInstance.status}

  if bookInstance.status!='Available'
    p #[strong Due back:] #{bookInstance.due_back_formatted}

  p Do you really want to delete this book copy?

    form(method='POST')
      div.form-group
        input#bookinstanceid.form-control(type='hidden', name='bookinstanceid', value=bookInstance._id )
        input#bookid.form-control(type='hidden', name='bookid', value=bookInstance.book._id )

      button.btn.btn-primary(type='submit') Delete